{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LLM Ranking Normalized Record",
  "description": "Schema for a single normalized benchmark record in the LLM Ranking pipeline",
  "type": "object",
  "required": ["model_id", "provider", "benchmark", "score", "date", "source_url"],
  "properties": {
    "model_id": {
      "type": "string",
      "description": "Canonical model identifier after mapping",
      "minLength": 1,
      "examples": ["gpt-4o", "claude-3.5-sonnet"]
    },
    "display_name": {
      "type": "string",
      "description": "Human-readable display name",
      "examples": ["GPT-4o", "Claude 3.5 Sonnet"]
    },
    "provider": {
      "type": "string",
      "description": "Model provider/vendor",
      "minLength": 1,
      "examples": ["openai", "anthropic", "google"]
    },
    "family": {
      "type": "string",
      "description": "Model family name",
      "examples": ["gpt-4", "claude-3"]
    },
    "benchmark": {
      "type": "string",
      "description": "Benchmark name identifier",
      "enum": ["arena_elo", "gpqa_diamond", "swe_bench", "livebench", "hle", "aime", "mmlu_pro"]
    },
    "score": {
      "type": "number",
      "description": "Normalized score value (0-100 scale or original scale)",
      "minimum": 0
    },
    "raw_score": {
      "type": "number",
      "description": "Original raw score before normalization",
      "minimum": 0
    },
    "z_score": {
      "type": "number",
      "description": "Z-score within its benchmark cohort"
    },
    "date": {
      "type": "string",
      "description": "Date when the score was recorded (ISO 8601 date)",
      "format": "date",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "source_url": {
      "type": "string",
      "format": "uri",
      "description": "URL to the source of the benchmark data"
    },
    "source_type": {
      "type": "string",
      "description": "Classification of the data source",
      "enum": ["independent_benchmark", "vendor_claim", "community_reported"],
      "default": "independent_benchmark"
    },
    "confidence": {
      "type": "number",
      "description": "Confidence score (0-1) for this data point",
      "minimum": 0,
      "maximum": 1,
      "default": 0.5
    },
    "fetched_at": {
      "type": "string",
      "description": "ISO 8601 timestamp of when this data was fetched",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
